# Copy this file to .env and fill in your values

PORT=5000

# MongoDB Atlas connection string (replace with your Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shopez?retryWrites=true&w=majority

# JWT Secret - use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# Your Vercel frontend URL (set this after deploying frontend)
CLIENT_URL=https://your-shopez.vercel.app

NODE_ENV=production
